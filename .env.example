# MyFinance - Environment Configuration
# Copy this file to .env and fill in your values.

# Application
APP_NAME=MyFinance
APP_VERSION=0.1.0
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-secret
APP_HOST=0.0.0.0
APP_PORT=8000

# Database
DATABASE_URL=mysql+mysqlconnector://user:password@localhost:3306/myfinance_db
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_PRE_PING=true

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash-latest
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_RETRIES=3

# LangChain
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=myfinance

# FAISS
FAISS_INDEX_PATH=data/embeddings/faiss_index.bin
FAISS_EMBEDDING_DIMENSION=768
FAISS_SIMILARITY_METRIC=cosine

# RAG
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5
RAG_MIN_SIMILARITY=0.7

# File Upload
UPLOAD_MAX_SIZE_MB=10
UPLOAD_ALLOWED_EXTENSIONS=.pdf,.csv,.xlsx,.docx,.txt

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=logs/myfinance.log
